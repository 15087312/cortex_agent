# 本地开发环境配置
# 复制此文件为 .env 并根据实际情况修改

# API 配置
# 用户身份（大模型知道谁在跟它说话）
USER_NAME=用户

OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_API_BASE_URL=https://api.deepseek.com/v1

# 大模型（DeepSeek-V4-Flash）
LARGE_MODEL_API_KEY=your_large_model_api_key
LARGE_MODEL_API_URL=https://api.deepseek.com/v1/chat/completions
LARGE_MODEL_NAME=deepseek-v4-flash
LARGE_MODEL_API_FORMAT=openai

# 中模型（DeepSeek）
MEDIUM_MODEL_API_KEY=your_medium_model_api_key
MEDIUM_MODEL_API_URL=https://api.deepseek.com/v1/chat/completions
MEDIUM_MODEL_NAME=deepseek-v4-flash

# 小模型（DeepSeek）
SMALL_MODEL_API_KEY=your_small_model_api_key
SMALL_MODEL_API_URL=https://api.deepseek.com/v1/chat/completions
SMALL_MODEL_NAME=deepseek-v4-flash

# 视觉模型
IMAGE_MODEL_NAME=gpt-4o

# Embedding/RAG 配置（默认仅用本地缓存，避免运行时阻塞连接 HuggingFace）
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_FOLDER=data/memory/embeddings/models
EMBEDDING_LOCAL_FILES_ONLY=True

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=100
REDIS_POOL_SIZE=100
REDIS_POOL_MAX_OVERFLOW=50
REDIS_POOL_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=2.0

# 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=humanoid_agi

# 连接池配置
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=100

# Docker 端口映射（本地开发）
POSTGRES_PORT_LOCAL=5432
REDIS_PORT_LOCAL=6379

# 向量数据库配置
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=6333
VECTOR_DB_DIMENSION=768

# 时序数据库配置
TIME_SERIES_DB_HOST=localhost
TIME_SERIES_DB_PORT=8086
TIME_SERIES_DB_NAME=humanoid_agi

# 系统配置
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO
MAX_WORKERS=10

# 记忆配置
MEMORY_TTL_SHORT=3600
MEMORY_TTL_LONG=86400
MEMORY_VECTOR_DIMENSION=768

# 注意力配置
ATTENTION_WEIGHT_THRESHOLD=0.7
INTERRUPT_URGENCY_THRESHOLD=0.9
