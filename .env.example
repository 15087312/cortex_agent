# ==================================================================
# Humanoid AGI — 环境配置示例
# ==================================================================
# 复制此文件为 .env 并根据需要修改
# 详细配置说明见：CONFIG_VALUE_EVOLUTION.md
# ==================================================================

# ===========================
# 用户配置
# ===========================
USER_NAME=用户

# ===========================
# 系统环境
# ===========================
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO
MAX_WORKERS=10

# ===========================
# 【核心】运行模式 — COMPANION_MODE
# ===========================
# False（工作模式）：完整工具委托，仅安全检测 ← 推荐生产环境
# True（陪伴模式）：情绪+价值观全开，委托受限 ← AI 助手模式
COMPANION_MODE=False

# ===========================
# 【核心】价值观进化系统
# ===========================
# 启用感知系统（规范违反实时检测）
PERCEPTION_ENABLED=True

# 启用差异检测器（后台对齐度趋势统计）
DIFFERENCE_DETECTOR_ENABLED=True

# 启用价值观对齐处理器（被动监测）
VALUE_ALIGNMENT_HANDLER_ENABLED=True

# ===========================
# 大模型配置
# ===========================
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE_URL=https://api.deepseek.com/v1

# 大模型（主协调模型）
LARGE_MODEL_API_KEY=your_large_model_api_key
LARGE_MODEL_API_URL=https://api.deepseek.com/v1/chat/completions
LARGE_MODEL_NAME=deepseek-v4-flash
LARGE_MODEL_API_FORMAT=openai
# 支持格式：openai / dashscope / anthropic（留空自动检测）

# 中模型（推理增强）
MEDIUM_MODEL_API_KEY=your_medium_model_api_key
MEDIUM_MODEL_API_URL=https://api.deepseek.com/v1/chat/completions
MEDIUM_MODEL_NAME=deepseek-v4-flash

# 小模型（轻量推理）
SMALL_MODEL_API_KEY=your_small_model_api_key
SMALL_MODEL_API_URL=https://api.deepseek.com/v1/chat/completions
SMALL_MODEL_NAME=deepseek-v4-flash

# 视觉模型配置
# VISION_BACKEND: auto / api / mlx / transformers / mock
#   auto=按优先级自动检测（api > mlx > transformers）
VISION_BACKEND=auto

# 云端视觉 API（VISION_BACKEND=api 时必填，auto 模式有 Key 即自动启用）
# VISION_API_KEY=your_api_key
# VISION_API_URL=https://api.openai.com/v1        # 留空复用 OPENAI_API_BASE_URL
# VISION_API_MODEL=gpt-4o                          # 模型名（gpt-4o / qwen-vl-max 等）
# VISION_API_FORMAT=openai                         # openai / dashscope / 留空自动检测

# 本地视觉模型（可选，留空用默认值）
# VISION_LOCAL_MODEL=Qwen/Qwen2-VL-2B-Instruct    # transformers 路径
# VISION_MLX_MODEL=mlx-community/Qwen2-VL-7B-Instruct-4bit  # MLX 路径（Apple Silicon）

# ===========================
# Embedding & RAG
# ===========================
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_FOLDER=data/memory/embeddings/models
EMBEDDING_LOCAL_FILES_ONLY=True

# ===========================
# 向量数据库
# ===========================
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=6333
VECTOR_DB_DIMENSION=768

# ===========================
# 上下文管理
# ===========================
# 大模型上下文窗口大小（token数）
# Qwen-Max: 128K, DeepSeek: 128K, GPT-4o: 128K, Claude: 200K
CONTEXT_WINDOW_SIZE=128000

# 触发压缩时，压缩到窗口的百分比（0.2 = 压缩到 20%）
CONTEXT_COMPRESS_RATIO=0.2

# ===========================
# 记忆配置
# ===========================
MEMORY_TTL_SHORT=3600        # 1 小时
MEMORY_TTL_LONG=86400        # 24 小时
MEMORY_VECTOR_DIMENSION=768

# ===========================
# 注意力系统
# ===========================
ATTENTION_WEIGHT_THRESHOLD=0.7
INTERRUPT_URGENCY_THRESHOLD=0.9
ATTENTION_IMPORTANCE_ENABLED=True
ATTENTION_IMPORTANCE_MODEL_ENABLED=False
ATTENTION_THRESHOLD_BASE=0.6
ATTENTION_THRESHOLD_SLOPE=0.5
ATTENTION_THRESHOLD_MIN=0.1
ATTENTION_THRESHOLD_MAX=0.6
ATTENTION_MAX_RECALL_LOW=5
ATTENTION_MAX_RECALL_MEDIUM=10
ATTENTION_MAX_RECALL_HIGH=20

# ===========================
# 安全配置
# ===========================
SECURITY_REVIEW_MODE=auto  # llm / user / auto

# ===========================
# 主动搭话（可选）
# ===========================
PROACTIVE_OUTREACH_ENABLED=True
PROACTIVE_OUTREACH_COOLDOWN_MINUTES=15
PROACTIVE_OUTREACH_IDLE_MINUTES=15
